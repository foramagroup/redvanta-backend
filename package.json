{
  "name": "krootal-review-backend",
  "version": "1.0.0",
  "description": "Backend complet Krootal Review – Node.js, Prisma, Stripe, NFC, Affiliates, Reviews automation",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "npx concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node prisma/seed.js",
    "migrate": "npx prisma migrate dev",
    "test": "jest",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:debug": "playwright test --debug",
    "ci:test": "npx playwright install --with-deps && playwright test",
    "sync-stripe": "node ./src/scripts/sync_stripe_products.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@prisma/client": "^5.22.0",
    "archiver": "^7.0.1",
    "axios": "^1.7.2",
    "basic-ftp": "^5.0.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "fabric": "^6.9.0",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.2.0",
    "joi": "^17.13.1",
    "json2csv": "^5.0.7",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lodash.debounce": "^4.0.8",
    "multer": "^1.4.5-lts.2",
    "mysql2": "^3.15.3",
    "nanoid": "^5.1.6",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.10",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "pm2": "^6.0.11",
    "qrcode": "^1.5.4",
    "react-leaflet": "^5.0.0",
    "sharp": "^0.34.5",
    "stripe": "^15.12.0",
    "twilio": "^4.1.0",
    "uuid": "^9.0.1",
    "webfontloader": "^1.6.28",
    "whatsapp-web.js": "^1.23.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/multer": "^2.0.0",
    "concurrently": "^8.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "playwright": "^1.42.0",
    "prisma": "^5.22.0"
  }
}

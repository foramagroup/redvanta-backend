  // Métadonnées
  icon        String?  @db.VarChar(50)
  color       String?  @db.VarChar(20)
  isPopular   Boolean  @default(false)
  status      AddonStatus @default(active)
  displayOrder Int     @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  

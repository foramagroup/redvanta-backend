model FeedbackFilteringConfig {
  id          Int      @id @default(autoincrement())
  companyId   Int      @unique    // 1:1 avec Company

  // ── Seuil de notation ─────────────────────────────────────
  // rating >= threshold → plateforme publique (Google, FB...)
  // rating <  threshold → formulaire interne
  threshold   Int      @default(4) // 1–5

  // ── Redirection plateforme publique ───────────────────────
  redirectPlatform  FilterRedirectPlatform @default(google)
  customUrl         String?  @db.VarChar(500) // si redirectPlatform = custom

  // ── Gestion des feedbacks privés ──────────────────────────

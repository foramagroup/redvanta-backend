  type        AddonType // usage_based, feature, capacity
  
  // Limites additionnelles (si type = capacity)
  apiBonus    Int?     @default(0)
  smsBonus    Int?     @default(0)
  webhookBonus Int?    @default(0)
  locationBonus Int?   @default(0)
  userBonus   Int?     @default(0)
  

model NFCTag {
  id          Int          @id @default(autoincrement())

  // Identifiant physique de la puce (lu lors du scan NFC hardware)
  // Optionnel car pas toujours lisible (ex: iPhone)
  tagSerial   String?      @unique @db.VarChar(64)

  // Type de puce (optionnel — gestion de stock multi-puces)
  // ex: "NTAG213", "NTAG215", "NTAG216"
  chipType    String?      @db.VarChar(50)

  // Statut physique de la puce
  status      NfcTagStatus @default(NEW)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relation : une puce peut être associée à une carte métier
  card        NFCCard?

  @@index([status])
  @@map("nfc_tags")
}


// NFCCard — Logique métier (carte vendue + utilisée)
// Représente la carte telle que le client la reçoit et l'utilise
// Contient TOUT ce qui est business : user, location, design, product
// ─────────────────────────────────────────────────────────────
model NFCCard {
  id          Int           @id @default(autoincrement())

  // uid : identifiant UUID unique stable — utilisé dans l'URL /r/{uid}
  // C'est cet uid qui est encodé dans le payload (QR + puce NFC)
  uid         String        @unique @db.VarChar(36)

  // Relation vers la puce hardware (optionnel au moment de la création,
  // assigné lors de la production physique)
  tagId       Int?          @unique
  tag         NFCTag?       @relation(fields: [tagId], references: [id], onDelete: SetNull)

  // ── Logique métier ──────────────────────────────────────────
  companyId   Int?          // nullable pour cartes pré-générées en stock
  userId      Int?          @db.UnsignedInt  // nullable pour cartes pré-générées
  locationId  Int?          // établissement associé
  designId    Int?          // design utilisé pour l'impression
  orderItemId     Int?
  customerId      Int?          // company assignée lors de l'attribution
  assignedAt      DateTime?     // date d'attribution à un client
  cardTemplateId  Int?          // template d'impression (stock pré-généré)

  // ── Payload (URL encodée dans QR + puce NFC) ────────────────
  // Format : https://app.redvanta.com/r/{uid}
  // JAMAIS le lien Google directement
  payload     String?       @db.VarChar(500)

  // URL du fichier image QR code généré
  qrCodeUrl   String?       @db.VarChar(500)

  // ── Données Google (destination finale) ─────────────────────
  googlePlaceId   String?   @db.VarChar(255)
  googleReviewUrl String?   @db.VarChar(500)
  locationName    String?   @db.VarChar(255)
  locationAddress String?   @db.VarChar(500)

  // ── Cycle de vie ────────────────────────────────────────────
  status      NfcCardStatus @default(NOT_PROGRAMMED)
  active      Boolean       @default(false)  // false jusqu'à DELIVERED
  used        Boolean       @default(false)  // a été scannée au moins une fois

  // ── Analytics dénormalisés (performance) ────────────────────
  scanCount           Int       @default(0)
  googleRedirectCount Int       @default(0)
  lastScannedAt       DateTime?

  // ── Dates métier ────────────────────────────────────────────
  generatedAt  DateTime?   // = date paiement
  activatedAt  DateTime?   // = date livraison

  batchId     String?     @db.VarChar(50)   // batch bulk qui a généré cette carte

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // ── Relations Prisma ────────────────────────────────────────
  company       Company?      @relation(fields: [companyId],      references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId],         references: [id], onDelete: Cascade)
  location      Location?     @relation(fields: [locationId],     references: [id], onDelete: SetNull)
  design        Design?       @relation(fields: [designId],       references: [id], onDelete: SetNull)
  orderItem     OrderItem?    @relation(fields: [orderItemId],    references: [id], onDelete: SetNull)
  cardTemplate  CardTemplate? @relation("NfcCardTemplate", fields: [cardTemplateId], references: [id], onDelete: SetNull)
  bulkBatch     BulkBatch?    @relation(fields: [batchId],        references: [id], onDelete: SetNull)
  scans       NfcScan[]
  events      AnalyticsEvent[]

  @@index([companyId])
  @@index([customerId])
  @@index([locationId])
  @@index([batchId])
  @@index([status])
  @@index([active])
  @@map("nfc_cards")
}


// ─── Scans NFC / QR ──────────────────────────────────────────
// Chaque fois qu'un client scanne la carte → on enregistre le scan
// Permet de savoir : combien de scans, d'où ils viennent, à quelle heure
model NfcScan {
  id         Int      @id @default(autoincrement())
  cardUid    String   @db.VarChar(36)   // NFCCard.uid
  companyId  Int

  scanType   String   @default("qr") @db.VarChar(10) // "nfc" | "qr"
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(500)
  deviceType String?  @db.VarChar(20)
  country    String?  @db.VarChar(100)

  scannedAt  DateTime @default(now())

  card       NFCCard  @relation(fields: [cardUid],   references: [uid], onDelete: Cascade)
  company    Company  @relation(fields: [companyId], references: [id],  onDelete: Cascade)

  @@index([cardUid])
  @@index([companyId])
  @@index([scannedAt])
  @@map("nfc_scans")
}



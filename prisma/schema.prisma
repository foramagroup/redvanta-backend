}


model Subscription {
  id              Int      @id @default(autoincrement())
  companyId       Int      @unique
  planId          Int
  
  // Statut et type
  status          SubscriptionStatus @default(active)
  interval        BillingInterval    @default(monthly)
  
  // Montants
  baseAmount      Float              // Prix du plan de base
  addonsAmount    Float    @default(0) // Total des add-ons
  totalAmount     Float              // baseAmount + addonsAmount
  
  // Facturation
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime
  lastBillingDate    DateTime?
  
  // Trial
  trialStart      DateTime?
  trialEnd        DateTime?
  
  // Annulation
  cancelAt        DateTime?
  canceledAt      DateTime?
  cancelReason    String?  @db.Text
  
  // Intégration Stripe
  stripeSubscriptionId String? @unique @db.VarChar(255)
  stripeCustomerId     String? @db.VarChar(255)
  
  // Métadonnées
  metadata        Json?    // Données supplémentaires
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activeCompany   Company?        @relation("ActiveSubscription")
  plan            PlanSetting     @relation(fields: [planId], references: [id], onDelete: Restrict)
  addons          SubscriptionAddon[]
  usageRecords    UsageRecord[]
  billingHistory  BillingHistory[]
  
  @@index([companyId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("subscriptions")
}


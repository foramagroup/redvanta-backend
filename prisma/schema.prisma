generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id             Int              @id @default(autoincrement())
  name           String           @unique(map: "name") @db.VarChar(255)
  createdAt      DateTime         @default(now()) @db.DateTime(0)
  updatedAt      DateTime         @default(now()) @db.DateTime(0)
  users       User[] 
  companies       UserCompany[] 
  rolepermission rolePermission[]
}

model User {
  id               Int             @id @default(autoincrement()) @db.UnsignedInt
  email            String          @unique
  password         String
  companyId        Int?     @db.UnsignedInt
  name             String?
  phone            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  isSuperadmin     Boolean         @default(false)
  isAdmin     Boolean         @default(false)
  superadminSince  DateTime?
  superadminLastAt DateTime?
  emailVerifiedAt  DateTime?
  emailVerifyToken String?         @unique @db.VarChar(255)
  emailVerifyExp   DateTime?


  emailVerifyCode     String?   @db.VarChar(6)   //Code à 6 chiffres
  emailVerifyCodeExp  DateTime?                  //Expiration du code
  emailVerifyAttempts Int       @default(0)      //Nombre de tentatives

  accountSuspendedAt DateTime?                  // Date de suspension
  suspensionReason   String?   @db.VarChar(255) // Raison suspension


  roleId           Int?
  twoFa            Boolean?        @default(false)
  lastLogin        DateTime?       @db.DateTime(0)
  welcomeToken     String?         @unique @db.VarChar(255)
  welcomeTokenExp  DateTime?
  design           Design[]
  orders Order[]
  cartItems CartItem[]

  logins           LoginActivity[]
  role             Role?       @relation(fields: [roleId], references: [id])
  companies        UserCompany[] 
  refreshTokens RefreshToken[]
  invoices     Invoice[]
  payments    Payment[]
  nfcCards NFCCard[]
  locationAssignments UserLocation[]
  activityLogs        TeamActivityLog[]
  reviewRequests ReviewRequest[]
  locations    Location[] @relation("OwnerLocations")
  auditLogs AuditLog[] @relation("AdminLogs")
  changedStatuses OrderStatusHistory[] @relation("StatusChangedBy")
  filteringAssignments FeedbackFilteringConfig[] @relation("FilterAssignedUser")
  aiCreditPurchases    AiCreditPurchase[]
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(500)
  userId    Int      @db.UnsignedInt
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("refresh_tokens")
}

model UserCompany {
  id        Int      @id @default(autoincrement())
  userId    Int      @db.UnsignedInt
  companyId Int
  roleId    Int?                    // rôle dans CETTE company (peut differ du rôle global)
  isOwner   Boolean  @default(true) // true = admin principal de la company
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId],    references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role?    @relation(fields: [roleId],    references: [id], onDelete: SetNull)

  @@unique([userId, companyId])   // un user ne peut être lié qu'une fois à une company
  @@index([companyId])
  @@index([userId])
  @@map("user_companies")
}

model PlatformSetting {
  id        Int      @id @default(autoincrement())
  
  sms_setting_id Int? @unique
  default_email_sender String?
  rate_limit Int @default(0)
  is_maIntenance Boolean @default(false)

  // General
  companyName    String?   @default("REDVANTA Inc.")
  companyEmail   String?   @default("contact@redvanta.com")
  companyPhone   String?
  companyCountry String ?  @default("United States")
  countryCode    String?   @default("+1")
  companyAddress String?  @db.Text
  vatNumber      String?
  tradeNumber    String?
  
  // Branding
  logoUrl        String?
  logoScale      Int      @default(100)
  primaryColor   String?   @default("#E10600")
  secondaryColor String?   @default("#1A1A1A")
  
  // reCAPTCHA
  captchaEnabled Boolean  @default(false)
  captchaSiteKey String?
  captchaSecret  String?
  
  // Google Maps
  mapsEnabled     Boolean  @default(false)
  mapsApiKey      String?
  mapsCloudSecret String?
  
  // Review Platforms
  googleLink      String?
  facebookLink    String?
  yelpLink        String?
  tripadvisorLink String?
  customReviewLink String?
  
  // Security
  twoFactorEnabled Boolean @default(false)
  twoFactorEmail   Boolean @default(false)
  twoFactorPhone   Boolean @default(false)
  twoFactorGoogle  Boolean @default(false)
  
  // Shipping
  shippingFallbackCost Float @default(14.99)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

   smsSetting   SmsSetting?  @relation(fields: [sms_setting_id], references: [id])

  @@map("platform_settings")
}

model ShippingRule {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(100)
  active   Boolean @default(true)
  priority Int     @default(10)

  // Geographic scope ("*" = global)
  country  String  @default("*") @db.VarChar(100)
  state    String? @db.VarChar(100)
  city     String? @db.VarChar(100)

  // Rule type: flat | free | weight | price | quantity
  type     String  @db.VarChar(20)

  // Flat rate
  flatCost        Float?
  // Free shipping
  freeMinTotal    Float?
  // Weight-based
  weightBaseCost  Float?
  weightCostPerKg Float?
  // Price tiers (JSON): [{ minTotal, maxTotal, cost }]
  priceTiers      Json?
  // Quantity tiers (JSON): [{ minQty, maxQty, cost }]
  quantityTiers   Json?

  // Optional cart/weight condition filters
  minTotal  Float?
  maxTotal  Float?
  minWeight Float?
  maxWeight Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([priority])
  @@map("shipping_rules")
}

model FrontPageSeo {
  id           Int                       @id @default(autoincrement())
  key          String                    @unique @db.VarChar(100)
  metaImage    String?                   @db.LongText
  isPublished  Boolean                   @default(true)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  translations FrontPageSeoTranslation[]

  @@index([isPublished])
  @@map("front_page_seo")
}

model FrontPageSeoTranslation {
  id         Int          @id @default(autoincrement())
  pageId     Int
  languageId Int
  name       String       @db.VarChar(255)
  slug       String       @db.VarChar(255)
  seoTitle   String?      @db.VarChar(255)
  seoDesc    String?      @db.Text

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  page       FrontPageSeo @relation(fields: [pageId],     references: [id], onDelete: Cascade)
  language   Language     @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([pageId, languageId])
  @@index([pageId])
  @@map("front_page_seo_translations")
}

model Location {
  id          Int      @id @default(autoincrement())
  companyId   Int
  ownerId     Int      @db.UnsignedInt
  name        String   @db.VarChar(255)
  slug        String?  @db.VarChar(191)
  address     String?  @db.VarChar(500)
  googlePlaceId   String?  @db.VarChar(255)
  googleReviewUrl String?  @db.VarChar(500)
  googleMapsUrl   String?  @db.VarChar(500)
  googleRating     Float?
  googleReviewCount Int?    @default(0)
  cardCount   Int      @default(0)
  city      String?
  postal    String?
  country   String?
  phone     String?
  email     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner       User     @relation("OwnerLocations", fields: [ownerId], references: [id], onDelete: Cascade)
  nfcCards NFCCard[]
  reviews   Review[]
  feedbacks Feedback[]
  reviewRequests ReviewRequest[]
  userAssignments     UserLocation[]

  @@index([companyId])
  @@index([slug])
  @@index([googlePlaceId])
  @@index([active])
  @@map("locations")
}

model UserLocation {
  id         Int      @id @default(autoincrement())
  userId     Int      @db.UnsignedInt
  companyId  Int
  locationId Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId],     references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId],  references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])   // un user ne peut être assigné qu'une fois à une location
  @@index([companyId])
  @@index([userId])
  @@map("user_locations")
}

model TeamActivityLog {
  id         Int      @id @default(autoincrement())
  companyId  Int
  userId     Int      @db.UnsignedInt  // membre qui a effectué l'action
  action     String   @db.VarChar(500) // description lisible ex: "Replied to review"
  category   String?  @db.VarChar(50)  // "review" | "request" | "auth" | "location" | "settings"
  metadata   Json?                     // données supplémentaires (reviewId, locationId...)
  createdAt  DateTime @default(now())

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@index([companyId, userId])
  @@index([createdAt])
  @@map("team_activity_logs")
}



model Conversion {
  id           Int      @id @default(autoincrement())
  orderId      Int
  currency     String   @db.VarChar(10)
  rate         Float
  displayTotal Float
  baseCurrency String   @default("EUR") @db.VarChar(10)
  baseTotal    Float    // montant réel en EUR

  createdAt    DateTime @default(now())

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("conversions")
}


model Review {
  id            String       @id @default(uuid()) @db.Char(36)
  locationId    Int?
  companyId     Int
  userId        String?
  userName      String?
  rating        Int
  comment       String?
  status        ReviewStatus @default(pending)
  email         String?
  phone         String?
  locationSlug  String?
  contact       String?
  source          String?
  googleReviewId  String?   @unique
  authorName      String?
  notifiedOwner Boolean      @default(false)
  postedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  location      Location?     @relation(fields: [locationId], references: [id])

  company       Company      @relation(fields: [companyId], references: [id])

  @@index([locationId])
  @@index([userId], map: "reviews_userId_fkey")
  @@map("reviews")
}




model Order {
 id            Int         @id @default(autoincrement())
  userId        Int         @db.UnsignedInt
  companyId     Int                          // ← company concernée
  orderNumber   String      @unique
  status        OrderStatus @default(pending)

  subtotal      Float
  shippingCost  Float       @default(0)
  total         Float

  methodPayment  String?
  trackingNumber   String?
  trackingUrl      String?
  estimatedDelivery DateTime?
  shippingFullName  String?
  shippingAddress   String?
  shippingCity      String?
  shippingState     String?
  shippingZip       String?
  shippingCountry   String?  @default("United States")
  shippingMethod    String?  @default("standard")
  shippingPhone     String?

  isCompany         Boolean  @default(false)
  companyName       String?
  taxId             String?

  stripePaymentIntentId String? @unique
  stripeClientSecret    String?
  paidAt                DateTime?
  confirmationEmailSentAt DateTime?

  currency     String?  @default("EUR")
  manualPaymentMethodId Int?
  displayTotal Float?
  exchangeRate Float?   @default(1)

  invoice      Invoice?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId],    references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  paymentMethod     ManualPaymentMethod?   @relation(fields: [manualPaymentMethodId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  Conversions Conversion[]
  payments    Payment[]
  statusHistory OrderStatusHistory[]


  @@index([userId, companyId])
  @@index([status])
  @@map("order")
}

model OrderStatusHistory {
  id          Int         @id @default(autoincrement())
  orderId     Int
  status      OrderStatus
  note        String?     @db.VarChar(500) // note interne du superadmin
  changedBy   Int?        @db.UnsignedInt  // userId du superadmin qui a changé
  changedAt   DateTime    @default(now())

  order       Order       @relation(fields: [orderId],   references: [id], onDelete: Cascade)
  admin       User?       @relation("StatusChangedBy", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([changedAt])
  @@map("order_status_history")
}


model Payment {
  id              Int               @id @default(autoincrement())
  // Références
  orderId         Int?              // lié à une commande (null si paiement manuel)
  invoiceId       Int?              // lié à une facture
  companyId       Int
  userId          Int               @db.UnsignedInt

  // Montants en EUR
  amount          Float
  currency        String            @default("EUR") @db.VarChar(10)
  exchangeRate    Float             @default(1)
  displayAmount   Float?            // montant dans la devise du client

  // Stripe
  stripePaymentIntentId String?     @db.VarChar(255)
  stripeChargeId        String?     @db.VarChar(255)
  stripeRefundId        String?     @db.VarChar(255)

  // Méthode de paiement
  method          PaymentMethodType @default(card)
  methodLabel     String?           @db.VarChar(100) // "Visa •••• 4242"
  last4           String?           @db.VarChar(4)
  brand           String?           @db.VarChar(30)  // "visa", "mastercard"...
  transactionId   String?           @db.VarChar(255) // ID externe (pour virement, chèque)

  // Statut
  status          PaymentStatus     @default(completed)
  failureMessage  String?           @db.Text

  // Notes
  notes           String?           @db.Text

  // Dates
  paidAt          DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  order           Order?            @relation(fields: [orderId],    references: [id], onDelete: SetNull)
  invoice         Invoice?          @relation(fields: [invoiceId],  references: [id], onDelete: SetNull)
  company         Company           @relation(fields: [companyId],  references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId],     references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([invoiceId])
  @@index([companyId])
  @@index([status])
  @@index([paidAt])
  @@map("payments")
}



model NotificationLog {
  id         String           @id @default(uuid()) @db.Char(36)
  type       NotificationType
  userId     String?
  locationId Int?
  status     String
  payload    String?
  error      String?
  createdAt  DateTime         @default(now())

  @@map("notification_logs")
}

model JobLog {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String
  status    String
  message   String?
  createdAt DateTime @default(now())

  @@map("job_logs")
}

model bundle {
  id            Int             @id @default(autoincrement())
  title         String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now())
  bundleproduct bundleproduct[]
}

model bundleproduct {
  id        Int     @id @default(autoincrement())
  bundleId  Int
  productId Int
  bundle    bundle  @relation(fields: [bundleId], references: [id], map: "BundleProduct_bundleId_fkey")
  product   Product @relation(fields: [productId], references: [id], map: "BundleProduct_productId_fkey")

  @@unique([bundleId, productId], map: "BundleProduct_bundleId_productId_key")
  @@index([productId], map: "BundleProduct_productId_fkey")
}





model dashboardstat {
  id        String   @id
  key       String   @unique(map: "dashboardStat_key_key")
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime
}


  model Design {
    id          Int             @id @default(autoincrement())
    userId      Int?            @db.UnsignedInt
    companyId   Int?
    productId   Int?
    status      DesignStatus    @default(draft)
    useLogo       Boolean @default(false) 

    // ── Step 1 : Business ─────────────────────────────────────
    businessName    String?
    slogan          String?
    callToAction    String?  @default("Powered by RedVanta")
    ctaPaddingTop   Int?     @default(8)          // ← NOUVEAU : espacement CTA en px
    googlePlaceId   String?
    googleReviewUrl String?
    platform    String?  @default("google")  // google|facebook|instagram|tiktok|tripadvisor|booking|airbnb|custom
    platformUrl String?                      // URL review/profil pour toutes plateformes non-Google
    redirectMode  String?  @db.VarChar(20)
 
    // ── Step 2 : Orientation & Logo ───────────────────────────
    orientation   DesignOrientation @default(landscape)
    orientations      String?   @db.VarChar(200)
    iconColor      String?   @db.VarChar(200)
    logoUrl       String?
    logoPosition  String?  @default("left")       // ← NOUVEAU : "left"|"right"|"top-center"|"top-left"...
    logoSize      Int?     @default(32)            // ← NOUVEAU : hauteur logo en px

    // ── Step 2 : Couleurs ─────────────────────────────────────
    colorMode   String?  @default("single")        // "single" | "template"
    bgColor     String?  @default("#0B0D0F")
    selectedIconId       String? 
    textColor   String?  @default("#FFFFFF")
    accentColor String?  @default("#E10600")       // = qrColor côté front
    starColor   String?  @default("#F59E0B")
    iconsColor  String?  @default("#22C55E")        // ← NOUVEAU : couleur checkmarks/icônes

    // ── Step 2 : Template & Bandes ───────────────────────────
    templateName    String?
    gradient1       String?  @default("#0B0D0F")   // ← NOUVEAU : couleur gradient 1 du template
    gradient2       String?  @default("#1A1A1A")   // ← NOUVEAU : couleur gradient 2 du template
    accentBand1     String?  @default("#E10600")   // ← NOUVEAU : couleur bande 1
    accentBand2     String?  @default("#FF4444")   // ← NOUVEAU : couleur bande 2
    bandPosition    String?  @default("bottom")    // ← NOUVEAU : "top"|"bottom"|"hidden"
    frontBandHeight Int?     @default(22)          // ← NOUVEAU : hauteur bande avant (%)
    backBandHeight  Int?     @default(12)          // ← NOUVEAU : hauteur bande arrière (%)

    // ── Step 2 : Icônes ──────────────────────────────────────
    showNfcIcon    Boolean  @default(true)          // ← NOUVEAU
    showGoogleIcon Boolean  @default(true)          // ← NOUVEAU
    nfcIconSize    Int?     @default(16)
    googleLogoSize Int?     @default(20)

    // ── Step 2 : Typographie — Nom ───────────────────────────
    businessFont          String?  @default("Space Grotesk")
    businessFontSize      Int?     @default(16)
    businessFontWeight    String?  @default("Bold")
    businessFontSpacing   String?  @default("Normal")   // id : "tight"|"normal"|"wide"|"wider"
    businessLineHeight    String?  @default("1.2")
    businessAlign         String?  @default("Left")
    businessTextTransform String?  @default("none")      // ← NOUVEAU : "none"|"uppercase"|"capitalize"

    // ── Step 2 : Typographie — Slogan ────────────────────────
    sloganFont          String?  @default("Inter")
    sloganFontSize      Int?     @default(12)
    sloganFontWeight    String?  @default("Regular")
    sloganFontSpacing   String?  @default("Normal")
    sloganLineHeight    String?  @default("1.4")
    sloganAlign         String?  @default("Left")
    sloganTextTransform String?  @default("none")        // ← NOUVEAU

    // ── Step 2 : Texte d'ombre ───────────────────────────────
    textShadow  String?  @default("None")              // "None"|"Subtle"|"Medium"|"Strong"|"Outline"

    // ── Step 2 : Instructions ────────────────────────────────
    frontInstruction1  String?  @default("Approach the phone to the card")
    frontInstruction2  String?  @default("Tap to leave a review")
    backInstruction1   String?
    backInstruction2   String?

    instrFont           String?  @default("Space Grotesk")
    instrFontSize       Int?     @default(10)
    instrFontWeight     String?  @default("Regular")
    instrFontSpacing    String?  @default("Normal")
    instrLineHeight     String?  @default("1.4")
    instrAlign          String?  @default("Left")
    instrCheckboxStyle  String?  @default("checkmark")
    checkStrokeWidth    Decimal? @default(3.5) @db.Decimal(3,1)  // ← NOUVEAU : 1.0 à 5.0

    // ── Step 2 : QR Code ─────────────────────────────────────
    qrCodeStyle  String?  @default("Left")            // position : "top"|"bottom"|"left"|"right"
    qrCodeSize   Int?     @default(60)

    // ── Step 2 : Modèle de carte ─────────────────────────────
    cardModel  CardModel  @default(classic)

    // ── Step 2 : Positions drag-and-drop ─────────────────────
    // JSON complet des offsets par orientation/face/élément
    // Format : { "landscape": { "front": { "businessInfo": {x,y}, "instructions": {x,y}, ... }, "back": {...} }, "portrait": {...} }
    elementOffsets  Json?

    // ── Serial Number Tag ─────────────────────────────────────
    showSerialNumber      Boolean? @default(false)
    serialNumber          String?  @db.VarChar(100)
    serialNumberTextColor String?  @db.VarChar(20)
    serialNumberBgColor   String?  @db.VarChar(30)
    serialNumberFontSize  Int?
    serialNumberPaddingX  Int?
    serialNumberPaddingY  Int?
    serialNumberRadius    Int?

    // ── Platform Icon Background ──────────────────────────────
    platformIconBgEnabled Boolean? @default(false)
    platformIconBgColor   String?  @db.VarChar(30)
    platformIconBgPadding Int?
    platformIconBgRadius  Int?
    platformIconBgShadow  Boolean? @default(false)

    isCustomized    Boolean   @default(false) // true dès que l'admin édite le design
    cardTemplateId  Int?                      // template d'origine (pour matching stock)

    // ── Step 3 : Review ──────────────────────────────────────
    version       Int       @default(1)
    lastAutoSave  DateTime?
    validatedAt   DateTime?

    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

    // Relations
    user         User?         @relation(fields: [userId],          references: [id], onDelete: Cascade)
    company      Company?      @relation(fields: [companyId],       references: [id], onDelete: Cascade)
    product      Product?      @relation(fields: [productId],       references: [id], onDelete: Cascade)
    cardTemplate CardTemplate? @relation("DesignTemplate", fields: [cardTemplateId], references: [id], onDelete: SetNull)
    cartItem    CartItem[]
    orderItem   OrderItem[]
    cartItemLocations CartItemLocation[]
    versions    DesignVersion[]
    nfcCards  NFCCard[]

    @@index([userId, companyId])
    @@index([status])
    @@map("designs")
  }



model GooglePlaceCache {
  id              Int      @id @default(autoincrement())

  // Clé du cache — ce qui a été recherché
  placeId         String   @unique @db.VarChar(255)  // Google Place ID (stable)

  // Données retournées par Google Places Details
  name            String?  @db.VarChar(255)
  formattedAddress String? @db.VarChar(500)
  phone           String?  @db.VarChar(50)
  website         String?  @db.VarChar(500)
  // Coordonnées GPS
  lat             Float?
  lng             Float?
  // Notes et avis
  rating          Float?
  userRatingsTotal Int?
  // URL directe pour laisser un avis (lien QR code)
  // Format : https://search.google.com/local/writereview?placeid=ChIJxxx
  reviewUrl       String?  @db.VarChar(500)
  // Photo principale (reference pour l'API Photos)
  photoReference  String?  @db.Text
  photoUrl        String?  @db.VarChar(500)
  // Catégorie principale
  types           Json?    // tableau de types Google Places

  // Cache metadata
  cachedAt        DateTime @default(now())
  expiresAt       DateTime // cachedAt + 30 jours

  @@index([placeId])
  @@index([expiresAt])  // pour la purge automatique
  @@map("google_place_cache")
}


model DesignVersion {
  id        Int      @id @default(autoincrement())
  designId  Int
  version   Int
  snapshot  Json
  savedAt   DateTime @default(now())
  design    Design   @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
  @@map("design_versions")
}


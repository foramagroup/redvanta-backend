generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id             Int              @id @default(autoincrement())
  name           String           @unique(map: "name") @db.VarChar(255)
  createdAt      DateTime         @default(now()) @db.DateTime(0)
  updatedAt      DateTime         @default(now()) @db.DateTime(0)
  users       User[] 
  companies       UserCompany[] 
  rolepermission rolePermission[]
}

model User {
  id               Int             @id @default(autoincrement()) @db.UnsignedInt
  email            String          @unique
  password         String
  companyId        Int?     @db.UnsignedInt
  name             String?
  phone            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  isSuperadmin     Boolean         @default(false)
  isAdmin     Boolean         @default(false)
  superadminSince  DateTime?
  superadminLastAt DateTime?
  emailVerifiedAt  DateTime?
  emailVerifyToken String?         @unique @db.VarChar(255)
  emailVerifyExp   DateTime?
  roleId           Int?
  twoFa            Boolean?        @default(false)
  lastLogin        DateTime?       @db.DateTime(0)
  welcomeToken     String?         @unique @db.VarChar(255)
  welcomeTokenExp  DateTime?
  affiliates       Affiliate?
  design           Design[]
  orders Order[]
  cartItems CartItem[]

  logins           LoginActivity[]
  role             Role?       @relation(fields: [roleId], references: [id])
  companies        UserCompany[] 
  refreshTokens RefreshToken[]
  auditLogs AuditLog[] @relation("AdminLogs")
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(500)
  userId    Int      @db.UnsignedInt
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("refresh_tokens")
}

model UserCompany {
  id        Int      @id @default(autoincrement())
  userId    Int      @db.UnsignedInt
  companyId Int
  roleId    Int?                    // rôle dans CETTE company (peut differ du rôle global)
  isOwner   Boolean  @default(true) // true = admin principal de la company
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId],    references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role?    @relation(fields: [roleId],    references: [id], onDelete: SetNull)

  @@unique([userId, companyId])   // un user ne peut être lié qu'une fois à une company
  @@index([companyId])
  @@index([userId])
  @@map("user_companies")
}

model PlatformSetting {
  id                   Int         @id @default(autoincrement()) @db.UnsignedInt
  platform_name        String      @db.VarChar(150)
  default_email_sender String      @db.VarChar(150)
  sms_setting_id       Int?        @db.UnsignedInt
  rate_limit           Int         @default(60)
  is_maIntenance       Boolean     @default(false)
  createdAt            DateTime    @default(now()) @db.Timestamp(0)
  updatedAt            DateTime    @default(now()) @db.Timestamp(0)
  smsSetting           SmsSetting? @relation(fields: [sms_setting_id], references: [id])
  @@index([sms_setting_id])
  @@map("platform_settings")
}



model Location {
  id        String    @id @default(uuid()) @db.Char(36)
  ownerId   Int?      @db.UnsignedInt
  name      String
  address   String?
  city      String?
  postal    String?
  country   String?
  phone     String?
  email     String?
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  nfcCards  NfcCard[]
  nfctag    nfctag[]
  reviews   Review[]

  @@index([ownerId])
  @@map("locations")
}



model Conversion {
  id          String    @id @default(uuid())
  orderId     Int
  affiliateId String
  amountCents Int
  currency    String    @default("EUR")
  createdAt   DateTime  @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id])

  @@index([affiliateId], map: "conversions_affiliateId_fkey")
  @@index([orderId], map: "conversions_orderId_fkey")
  @@map("conversions")
}

model NfcCard {
  id         String    @id @default(uuid()) @db.Char(36)
  locationId String
  uid        String    @unique
  title      String?
  url        String?
  createdAt  DateTime  @default(now())
  location   Location  @relation(fields: [locationId], references: [id])
  scans      NfcScan[]

  @@index([locationId], map: "nfc_cards_locationId_fkey")
  @@map("nfc_cards")
}

model NfcScan {
  id        String   @id @default(uuid()) @db.Char(36)
  cardId    String
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
  card      NfcCard  @relation(fields: [cardId], references: [id])

  @@index([cardId], map: "nfc_scans_cardId_fkey")
  @@map("nfc_scans")
}

model Review {
  id            String       @id @default(uuid()) @db.Char(36)
  locationId    String
  userId        String?
  userName      String?
  rating        Int
  comment       String?
  status        ReviewStatus @default(pending)
  email         String?
  phone         String?
  locationSlug  String?
  contact       String?
  source        String?
  notifiedOwner Boolean      @default(false)
  postedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  location      Location     @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@index([userId], map: "reviews_userId_fkey")
  @@map("reviews")
}

model Order {
 id            Int         @id @default(autoincrement())
  userId        Int         @db.UnsignedInt
  companyId     Int                          // ← company concernée
  orderNumber   String      @unique
  status        OrderStatus @default(pending)

  subtotal      Float
  shippingCost  Float       @default(0)
  total         Float

  shippingFullName  String?
  shippingAddress   String?
  shippingCity      String?
  shippingState     String?
  shippingZip       String?
  shippingCountry   String?  @default("United States")
  shippingMethod    ShippingMethod @default(standard)

  stripePaymentIntentId String? @unique
  stripeClientSecret    String?
  paidAt                DateTime?
  confirmationEmailSentAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId],    references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items       OrderItem[]
  Conversions Conversion[]


  @@index([userId, companyId])
  @@index([status])
  @@map("order")
}

model Affiliate {
  id              String              @id @default(uuid()) @db.Char(36)
  userId          Int?                @unique @db.UnsignedInt
  name            String?
  email           String?
  refCode         String              @unique
  revenue         Float               @default(0)
  stripeAccountId String?
  iban            String?
  createdAt       DateTime            @default(now())
  tracking        AffiliateTracking[]
  user            User?               @relation(fields: [userId], references: [id], onDelete: Cascade, map: "affiliates_userId_key")
  click           click[]
  conversions     Conversion[]
  payoutrequest   payoutrequest[]

  @@map("affiliates")
}

model AffiliateTracking {
  id          String    @id @default(uuid()) @db.Char(36)
  affiliateId String
  orderId     String?
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId], map: "affiliate_tracking_affiliateId_fkey")
  @@index([orderId])
  @@map("affiliate_tracking")
}

model NotificationLog {
  id         String           @id @default(uuid()) @db.Char(36)
  type       NotificationType
  userId     String?
  locationId String?
  status     String
  payload    String?
  error      String?
  createdAt  DateTime         @default(now())

  @@map("notification_logs")
}

model JobLog {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String
  status    String
  message   String?
  createdAt DateTime @default(now())

  @@map("job_logs")
}

model bundle {
  id            Int             @id @default(autoincrement())
  title         String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now())
  bundleproduct bundleproduct[]
}

model bundleproduct {
  id        Int     @id @default(autoincrement())
  bundleId  Int
  productId Int
  bundle    bundle  @relation(fields: [bundleId], references: [id], map: "BundleProduct_bundleId_fkey")
  product   Product @relation(fields: [productId], references: [id], map: "BundleProduct_productId_fkey")

  @@unique([bundleId, productId], map: "BundleProduct_bundleId_productId_key")
  @@index([productId], map: "BundleProduct_productId_fkey")
}

model click {
  id          String    @id
  affiliateId String
  ip          String?
  userAgent   String?
  referer     String?
  cookie      String?
  createdAt   DateTime  @default(now())
  affiliates  Affiliate @relation(fields: [affiliateId], references: [id], map: "Click_affiliateId_fkey")

  @@index([affiliateId], map: "Click_affiliateId_fkey")
}

model customization {
  id        String   @id
  orderId   String   @unique(map: "Customization_orderId_key")
  frontData String   @db.Text
  backData  String   @db.Text
  costCents Int
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model dashboardstat {
  id        String   @id
  key       String   @unique(map: "dashboardStat_key_key")
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime
}


  model Design {
    id          Int             @id @default(autoincrement())
    userId      Int             @db.UnsignedInt
    companyId   Int
    productId   Int
    status      DesignStatus    @default(draft)

    // ── Step 1 : Business ─────────────────────────────────────
    businessName    String?
    slogan          String?
    callToAction    String?  @default("Powered by RedVanta")
    ctaPaddingTop   Int?     @default(8)          // ← NOUVEAU : espacement CTA en px
    googlePlaceId   String?
    googleReviewUrl String?

    // ── Step 2 : Orientation & Logo ───────────────────────────
    orientation   DesignOrientation @default(landscape)
    logoUrl       String?
    logoPosition  String?  @default("left")       // ← NOUVEAU : "left"|"right"|"top-center"|"top-left"...
    logoSize      Int?     @default(32)            // ← NOUVEAU : hauteur logo en px

    // ── Step 2 : Couleurs ─────────────────────────────────────
    colorMode   String?  @default("single")        // "single" | "template"
    bgColor     String?  @default("#0B0D0F")
    textColor   String?  @default("#FFFFFF")
    accentColor String?  @default("#E10600")       // = qrColor côté front
    starColor   String?  @default("#F59E0B")
    iconsColor  String?  @default("#22C55E")        // ← NOUVEAU : couleur checkmarks/icônes

    // ── Step 2 : Template & Bandes ───────────────────────────
    templateName    String?
    gradient1       String?  @default("#0B0D0F")   // ← NOUVEAU : couleur gradient 1 du template
    gradient2       String?  @default("#1A1A1A")   // ← NOUVEAU : couleur gradient 2 du template
    accentBand1     String?  @default("#E10600")   // ← NOUVEAU : couleur bande 1
    accentBand2     String?  @default("#FF4444")   // ← NOUVEAU : couleur bande 2
    bandPosition    String?  @default("bottom")    // ← NOUVEAU : "top"|"bottom"|"hidden"
    frontBandHeight Int?     @default(22)          // ← NOUVEAU : hauteur bande avant (%)
    backBandHeight  Int?     @default(12)          // ← NOUVEAU : hauteur bande arrière (%)

    // ── Step 2 : Icônes ──────────────────────────────────────
    showNfcIcon    Boolean  @default(true)          // ← NOUVEAU
    showGoogleIcon Boolean  @default(true)          // ← NOUVEAU
    nfcIconSize    Int?     @default(16)
    googleLogoSize Int?     @default(20)

    // ── Step 2 : Typographie — Nom ───────────────────────────
    businessFont          String?  @default("Space Grotesk")
    businessFontSize      Int?     @default(16)
    businessFontWeight    String?  @default("Bold")
    businessFontSpacing   String?  @default("Normal")   // id : "tight"|"normal"|"wide"|"wider"
    businessLineHeight    String?  @default("1.2")
    businessAlign         String?  @default("Left")
    businessTextTransform String?  @default("none")      // ← NOUVEAU : "none"|"uppercase"|"capitalize"

    // ── Step 2 : Typographie — Slogan ────────────────────────
    sloganFont          String?  @default("Inter")
    sloganFontSize      Int?     @default(12)
    sloganFontWeight    String?  @default("Regular")
    sloganFontSpacing   String?  @default("Normal")
    sloganLineHeight    String?  @default("1.4")
    sloganAlign         String?  @default("Left")
    sloganTextTransform String?  @default("none")        // ← NOUVEAU

    // ── Step 2 : Texte d'ombre ───────────────────────────────
    textShadow  String?  @default("None")              // "None"|"Subtle"|"Medium"|"Strong"|"Outline"

    // ── Step 2 : Instructions ────────────────────────────────
    frontInstruction1  String?  @default("Approach the phone to the card")
    frontInstruction2  String?  @default("Tap to leave a review")
    backInstruction1   String?
    backInstruction2   String?

    instrFont           String?  @default("Space Grotesk")
    instrFontSize       Int?     @default(10)
    instrFontWeight     String?  @default("Regular")
    instrFontSpacing    String?  @default("Normal")
    instrLineHeight     String?  @default("1.4")
    instrAlign          String?  @default("Left")
    instrCheckboxStyle  String?  @default("checkmark")
    checkStrokeWidth    Decimal? @default(3.5) @db.Decimal(3,1)  // ← NOUVEAU : 1.0 à 5.0

    // ── Step 2 : QR Code ─────────────────────────────────────
    qrCodeStyle  String?  @default("Left")            // position : "top"|"bottom"|"left"|"right"
    qrCodeSize   Int?     @default(60)

    // ── Step 2 : Modèle de carte ─────────────────────────────
    cardModel  CardModel  @default(classic)

    // ── Step 2 : Positions drag-and-drop ─────────────────────
    // JSON complet des offsets par orientation/face/élément
    // Format : { "landscape": { "front": { "businessInfo": {x,y}, "instructions": {x,y}, ... }, "back": {...} }, "portrait": {...} }
    elementOffsets  Json?                               // ← NOUVEAU

    // ── Step 3 : Review ──────────────────────────────────────
    version       Int       @default(1)
    lastAutoSave  DateTime?
    validatedAt   DateTime?

    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

    // Relations
    user        User        @relation(fields: [userId],    references: [id], onDelete: Cascade)
    company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
    product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
    cartItem    CartItem?
    orderItem   OrderItem?
    versions    DesignVersion[]
    nfctags     nfctag[]

    @@index([userId, companyId])
    @@index([status])
    @@map("designs")
  }



model GooglePlaceCache {
  id              Int      @id @default(autoincrement())

  // Clé du cache — ce qui a été recherché
  placeId         String   @unique @db.VarChar(255)  // Google Place ID (stable)

  // Données retournées par Google Places Details
  name            String?  @db.VarChar(255)
  formattedAddress String? @db.VarChar(500)
  phone           String?  @db.VarChar(50)
  website         String?  @db.VarChar(500)
  // Coordonnées GPS
  lat             Float?
  lng             Float?
  // Notes et avis
  rating          Float?
  userRatingsTotal Int?
  // URL directe pour laisser un avis (lien QR code)
  // Format : https://search.google.com/local/writereview?placeid=ChIJxxx
  reviewUrl       String?  @db.VarChar(500)
  // Photo principale (reference pour l'API Photos)
  photoReference  String?  @db.Text
  photoUrl        String?  @db.VarChar(500)
  // Catégorie principale
  types           Json?    // tableau de types Google Places

  // Cache metadata
  cachedAt        DateTime @default(now())
  expiresAt       DateTime // cachedAt + 30 jours

  @@index([placeId])
  @@index([expiresAt])  // pour la purge automatique
  @@map("google_place_cache")
}


model DesignVersion {
  id        Int      @id @default(autoincrement())
  designId  Int
  version   Int
  snapshot  Json
  savedAt   DateTime @default(now())
  design    Design   @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
  @@map("design_versions")
}

model emailQueue {
  id          String    @id
  to          String
  subject     String
  html        String    @db.Text
  text        String?   @db.Text
  processed   Boolean   @default(false)
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  @@map("emailqueue")
}

model nfctag {
  id         String    @id
  uid        String?   @unique(map: "NFCTag_uid_key")
  tagSerial  String?
  qrCodeFile String?
  payload    String?   @db.Text
  used       Boolean   @default(false)
  active     Boolean   @default(true)
  locationId String?
  productId  Int?
  userId     String?
  designId   Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())
  design     Design?   @relation(fields: [designId], references: [id], map: "NFCTag_designId_fkey")
  locations  Location? @relation(fields: [locationId], references: [id], map: "NFCTag_locationId_fkey")
  product    Product?  @relation(fields: [productId], references: [id], map: "NFCTag_productId_fkey")
  scanlog    scanlog[]

  @@index([designId], map: "NFCTag_designId_fkey")
  @@index([locationId], map: "NFCTag_locationId_fkey")
  @@index([productId], map: "NFCTag_productId_fkey")
  @@index([userId], map: "NFCTag_userId_fkey")
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  productId       Int
  packageTierId   Int?     // snapshot du tier choisi
  totalCards      Int      // nombre de cartes commandées
  quantity        Int      // = totalCards (alias afichage)
  unitPrice       Float    // prix/carte (snapshot)
  totalPrice      Float    // lineTotal (snapshot)
  designId        Int?     @unique
  cardTypeId      Int?

  order       Order              @relation(fields: [orderId],        references: [id], onDelete: Cascade)
  product     Product            @relation(fields: [productId],      references: [id], onDelete: Restrict)
  packageTier ProductPackageTier? @relation(fields: [packageTierId], references: [id], onDelete: SetNull)
  design      Design?            @relation(fields: [designId],       references: [id], onDelete: SetNull)
  cardType    CardType?          @relation(fields: [cardTypeId],     references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

model payoutrequest {
  id               String    @id
  affiliateId      String
  amountCents      Int
  currency         String    @default("EUR")
  status           String    @default("pending")
  stripeTransferId String?
  stripePayoutId   String?
  note             String?
  requestedAt      DateTime  @default(now())
  processedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  affiliates       Affiliate @relation(fields: [affiliateId], references: [id], map: "PayoutRequest_affiliateId_fkey")

  @@index([affiliateId], map: "PayoutRequest_affiliateId_fkey")
}

model ShippingRate {
  id          Int            @id @default(autoincrement())
  method      ShippingMethod @unique
  label       String
  description String?
  price       Float
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  @@map("shipping_rates")
}





model scanlog {
  id       String   @id
  nfcTagId String
  ip       String?
  agent    String?
  lat      Float?
  lon      Float?
  country  String?
  city     String?
  at       DateTime @default(now())
  nfctag   nfctag   @relation(fields: [nfcTagId], references: [id], map: "ScanLog_nfcTagId_fkey")

  @@index([nfcTagId], map: "ScanLog_nfcTagId_fkey")
}

model setting {
  id        String   @id
  key       String   @unique(map: "Setting_key_key")
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model SmsRegion {
  id          Int          @id @default(autoincrement()) @db.UnsignedInt
  name        String       @db.VarChar(100)
  createdAt   DateTime     @default(now()) @db.Timestamp(0)
  updatedAt   DateTime     @default(now()) @db.Timestamp(0)
  smsSettings SmsSetting[]

  @@map("sms_regions")
}

model SmsSupplier {
  id          Int          @id @default(autoincrement()) @db.UnsignedInt
  name        String       @db.VarChar(100)
  createdAt   DateTime     @default(now()) @db.Timestamp(0)
  updatedAt   DateTime     @default(now()) @db.Timestamp(0)
  smsSettings SmsSetting[]

  @@map("sms_suppliers")
}

model SmsSetting {
  id               Int               @id @default(autoincrement()) @db.UnsignedInt
  supplier_id      Int               @db.UnsignedInt
  region_id        Int               @db.UnsignedInt
  api_key          String?           @db.VarChar(255)
  auth_token       String?           @db.VarChar(255)
  phone_number     String?           @db.VarChar(50)
  set_default      Boolean?          @default(false)
  status           Boolean?          @default(true)
  createdAt        DateTime          @default(now()) @db.Timestamp(0)
  updatedAt        DateTime          @default(now()) @db.Timestamp(0)
  platformSettings PlatformSetting[]
  region           SmsRegion         @relation(fields: [region_id], references: [id], onDelete: Cascade, map: "fk_sms_region")
  supplier         SmsSupplier       @relation(fields: [supplier_id], references: [id], onDelete: Cascade, map: "fk_sms_supplier")

  @@index([region_id], map: "fk_sms_region")
  @@index([supplier_id], map: "fk_sms_supplier")
  @@map("sms_settings")
}


model SuperAdminSetting {
  id        Int      @id @default(autoincrement())
  module    String   @unique @db.VarChar(100)
  settings  String?  @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admin_settings")
}


model EmailServerConfig {
  id        String   @id @db.VarChar(191)
  name      String   @db.VarChar(150)
  value     String   @db.VarChar(100)
  sid       String   @db.VarChar(30)
  region    String?  @db.VarChar(100)
  status    String   @default("Active") @db.VarChar(30)
  isDefault Boolean  @default(false)
  config    String?  @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_server_config")
}

model stripeproduct {
  id             String   @id
  stripeId       String   @unique(map: "StripeProduct_stripeId_key")
  localProductId Int?
  createdAt      DateTime @default(now())
}



model template {
  id          String   @id
  name        String
  filename    String
  description String?
  createdAt   DateTime @default(now())
}

model upsell {
  id        String   @id
  productId Int
  title     String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], map: "Upsell_productId_fkey")

  @@index([productId], map: "Upsell_productId_fkey")
}

model webhooklog {
  id          String            @id
  provider    String
  payload     String            @db.Text
  status      webhooklog_status @default(pending)
  error       String?
  createdAt   DateTime          @default(now())
  processedAt DateTime?
}

model LoginActivity {
  id         Int       @id @default(autoincrement())
  userId     Int?      @db.UnsignedInt
  admin_name String?
  userAgent String? @db.VarChar(500)
  ip         String?
  status     String?   @db.VarChar(50)
  createdAt  DateTime? @default(now()) @db.DateTime(0)

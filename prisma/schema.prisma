model Company {
  id             Int      @id @default(autoincrement())
  name           String
  logo        String?
  googlePlaceId        String?
  googleReviewUrl        String?
  logoScale      Int      @default(100)
  vatNumber      String?
  tradeNumber    String?
  email          String   @unique
  phone          String?
  country        String?
  address        String?  @db.Text
  type              CompanyType     @default(direct)
  planId           Int?   
  status            CompanyStatus   @default(active)
  defaultLanguageId Int?  
  primaryColor   String   @default("#E10600")
  
  captchaEnabled Boolean  @default(false)
  captchaSiteKey String?
  captchaSecret  String?
  mapsEnabled    Boolean  @default(false)
  mapsApiKey     String?
  
  googleLink     String?
  facebookLink   String?
  yelpLink       String?
  tripadvisorLink String?

  billingAmount     String?
  billingDate       DateTime?
  billingNextDate   DateTime?

  mrr               Int             @default(0)
  apiUsageCount     Int             @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  package           PlanSetting?    @relation(fields: [planId], references: [id], onDelete: SetNull, map: "companies_planId_foreign")
  defaulLanguage    Language?       @relation(fields: [defaultLanguageId], references: [id], onDelete: SetNull, map: "companies_defaultLanguageId_foreign")
